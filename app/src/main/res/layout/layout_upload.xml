<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.02"
        android:text="@string/app_name"
        android:textColor="@color/tokyo_text_bright"
        android:textSize="34sp" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Upscale your images 2x or 4x"
        android:textColor="@color/tokyo_text_muted"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="28dp"
        android:layout_weight="1"
        android:minHeight="240dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/tokyo_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/tokyo_border"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/imagePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/imagePlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/upload_placeholder_bg"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/tokyo_text_muted"
                android:textSize="48sp" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/fileInfoGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/imageNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tokyo_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/imageSizeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/tokyo_text_muted"
            android:textSize="12sp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/scaleToggleGroup"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        app:checkedButton="@+id/scale2x"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scale2x"
            style="@style/Widget.Upscale.ToggleButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="2x" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scale4x"
            style="@style/Widget.Upscale.ToggleButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="4x" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/upscaleButton"
        style="@style/Widget.Upscale.Button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:enabled="false"
        android:text="Upscale" />

</LinearLayout>
