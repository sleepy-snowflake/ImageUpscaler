<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.02"
        android:text="Upscaling"
        android:textColor="@color/tokyo_text_bright"
        android:textSize="34sp" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loadingSpinner"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="48dp"
        android:indeterminate="true"
        app:indicatorColor="@color/tokyo_primary"
        app:indicatorSize="48dp"
        app:trackColor="@color/tokyo_surface_elevated"
        app:trackThickness="3dp" />

    <TextView
        android:id="@+id/stageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/tokyo_text_muted"
        android:textSize="15sp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:indeterminate="false"
        app:indicatorColor="@color/tokyo_primary"
        app:trackColor="@color/tokyo_surface_elevated"
        app:trackThickness="3dp" />

</LinearLayout>
