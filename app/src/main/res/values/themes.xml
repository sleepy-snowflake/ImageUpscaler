<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Upscale" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:statusBarColor">@color/tokyo_bg</item>
        <item name="android:navigationBarColor">@color/tokyo_bg</item>
        <item name="android:windowBackground">@color/tokyo_bg</item>

        <item name="colorPrimary">@color/tokyo_primary</item>
        <item name="colorOnPrimary">@color/tokyo_on_primary</item>
        <item name="colorPrimaryContainer">@color/tokyo_accent</item>
        <item name="colorSecondary">@color/tokyo_secondary</item>
        <item name="colorOnSecondary">@color/tokyo_bg</item>
        <item name="colorSurface">@color/tokyo_surface</item>
        <item name="colorOnSurface">@color/tokyo_text</item>
        <item name="android:colorBackground">@color/tokyo_bg</item>
        <item name="colorOnBackground">@color/tokyo_text</item>
        <item name="colorError">@color/tokyo_error</item>
        <item name="colorOnError">@color/tokyo_bg</item>
        <item name="colorOutline">@color/tokyo_border</item>

        <item name="materialCardViewStyle">@style/Widget.Upscale.Card</item>
        <item name="materialButtonStyle">@style/Widget.Upscale.Button</item>
    </style>

    <style name="Widget.Upscale.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/tokyo_surface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/tokyo_border</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.Upscale.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Upscale.Small</item>
    </style>

    <style name="Widget.Upscale.ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Upscale.Small</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/tokyo_border</item>
    </style>

    <style name="ShapeAppearance.Upscale.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>
